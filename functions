# GCP project switcher (similar to AWS plugin's `asp` and OCI's `osp`)
# Usage: gsp                   - list projects and show current
#        gsp <alias>           - switch to project by alias
#        gsp <alias> <region>  - switch project and set region
function gsp() {
  # Compatible with both zsh and bash
  local aliases="dev test stage prod sandbox bootstrap"
  local _gsp_project() {
    case "$1" in
      dev)       echo "pb-development-9yc6" ;;
      test)      echo "pb-testing-v2cc" ;;
      stage)     echo "pb-staging-9gps" ;;
      prod)      echo "pb-production-gxyx" ;;
      infra)     echo "pb-infra-lr1e" ;;
      sandbox)   echo "pb-sandbox-q1vr" ;;
      bootstrap) echo "pb-bootstrap-6363" ;;
    esac
  }

  if [[ -z "$1" ]]; then
    local current
    current=$(gcloud config get-value project 2>/dev/null)
    echo "Current project: ${current:-(none)}"
    echo ""
    echo "Available aliases:"
    for a in $aliases; do
      local pid marker=""
      pid=$(_gsp_project "$a")
      [[ "$pid" == "$current" ]] && marker=" <-- active"
      printf "  %-10s %s%s\n" "$a" "$pid" "$marker"
    done
    unset -f _gsp_project
    return
  fi

  local project_id
  project_id=$(_gsp_project "$1")
  unset -f _gsp_project
  if [[ -z "$project_id" ]]; then
    echo "Unknown alias '$1'. Available: $aliases" >&2
    return 1
  fi

  local set_output
  set_output=$(gcloud config set project "$project_id" 2>&1)
  if echo "$set_output" | grep -q "Reauthentication required\|Please run.*gcloud auth login"; then
    echo "Reauthentication required, logging in..."
    gcloud auth login --update-adc || return 1
    gcloud config set project "$project_id"
  fi
  export GOOGLE_CLOUD_QUOTA_PROJECT="$project_id"

  if [[ -n "$2" ]]; then
    gcloud config set compute/region "$2"
    echo "Switched to GCP project: $project_id (region: $2)"
  else
    echo "Switched to GCP project: $project_id"
  fi
}

# Show current GCP config
function gcp_profile() {
  echo "Project:  $(gcloud config get-value project 2>/dev/null || echo '(none)')"
  echo "Region:   $(gcloud config get-value compute/region 2>/dev/null || echo '(none)')"
  echo "Account:  $(gcloud config get-value account 2>/dev/null || echo '(none)')"
  echo "GOOGLE_CLOUD_QUOTA_PROJECT: ${GOOGLE_CLOUD_QUOTA_PROJECT:-(not set)}"
}

# Oracle OCI SSO session login
function ocisso() {
  export OCI_AUTH=SecurityToken
  oci session refresh --profile "DEFAULT" 2>/dev/null || \
    oci session authenticate --region "eu-frankfurt-1" --profile-name "DEFAULT"
}

# Show current OCI profile and auth settings
function oci_profile() {
  echo "OCI_CONFIG_FILE_PROFILE: ${OCI_CONFIG_FILE_PROFILE:-DEFAULT}"
  echo "OCI_AUTH:                ${OCI_AUTH:-(not set, using APIKey)}"
  echo "OCI_REGION:              ${OCI_REGION:-eu-frankfurt-1}"
}

# Quick secret decode from Kubernetes
function kdecode() {
  kubectl get secret "$1" -o json | jq -r '.data | map_values(@base64d)'
}

# yazi
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}
