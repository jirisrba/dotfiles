#!/usr/bin/env bash

# man color pages
function man() {
  env \
    LESS_TERMCAP_mb=$(printf "\e[1;31m") \
    LESS_TERMCAP_md=$(printf "\e[1;38;5;74m") \
    LESS_TERMCAP_so=$(printf "\e[38;5;246m") \
    LESS_TERMCAP_us=$(printf "\e[04;38;5;146m") \
    LESS_TERMCAP_me=$(printf "\e[0m") \
    LESS_TERMCAP_ue=$(printf "\e[0m") \
    LESS_TERMCAP_se=$(printf "\e[0m") \
    man "$@"
}

# git
function gac() {
  if [[ -z "$*" ]]; then
    echo "Error: Commit message required"
    return 1
  fi
  git add -A && git commit -m "$*" && git push --follow-tags
}

function gcf() {
  # gcf --no-verify
  git add -A && git commit --fixup=HEAD "$@" &&
    git checkout -- . &&
    git rebase -i --autosquash $(basename $(git symbolic-ref --short refs/remotes/origin/HEAD)) &&
    git push --follow-tags --force-with-lease
}

# Create PR for Github
function ghprc() {
  num_commits=$(git rev-list --count HEAD ^origin)
  if [[ $num_commits -gt 1 ]]; then
    gh pr create --fill --title "$(git branch --show-current)"
  else
    gh pr create --title "$(git branch --show-current)" --body "$(git log --pretty=format:%s HEAD ^origin)"
  fi
}

# Open current PR in browser
function ghpr() {
  gh pr view --web
}

# Create MR for GitLab
function glmrc() {
  num_commits=$(git rev-list --count HEAD ^origin)
  if [[ $num_commits -gt 1 ]]; then
    glab mr create --fill --title "$(git branch --show-current)" --assignee jiri.srba --remove-source-branch
  else
    glab mr create --title "$(git branch --show-current)" --description "$(git log --pretty=format:%s HEAD ^origin)" --assignee jiri.srba --remove-source-branch
  fi
}

# Open current MR in browser
function glmr() {
  glab mr view --web
}

